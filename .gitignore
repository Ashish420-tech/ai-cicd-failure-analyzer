```gitignore
# ==========================================
# Python
# ==========================================
__pycache__/
*.py[cod]
*.pyo
*.pyd
*.so
*.egg
*.egg-info/
build/
dist/
pip-wheel-metadata/

# ==========================================
# Virtual Environment
# ==========================================
venv/
.venv/
env/
ENV/

# ==========================================
# Environment Variables
# ==========================================
.env
.env.*

# ==========================================
# IDE
# ==========================================
.vscode/
.idea/
*.swp

# ==========================================
# OS Files
# ==========================================
.DS_Store
Thumbs.db

# ==========================================
# Python Testing
# ==========================================
.pytest_cache/
.coverage
htmlcov/
.tox/
.mypy_cache/

# ==========================================
# Jupyter
# ==========================================
.ipynb_checkpoints/

# ==========================================
# Logs
# ==========================================
*.log

# Keep sample logs
!logs/
!logs/*.log

# ==========================================
# Reports
# ==========================================
reports/
*.pdf

# ==========================================
# Temporary Files
# ==========================================
*.tmp
*.bak

# ==========================================
# Local Database
# ==========================================
*.db
*.sqlite3

# ==========================================
# Cache
# ==========================================
.cache/

# ==========================================
# Node.js (if used later)
# ==========================================
node_modules/

# ==========================================
# Terraform (future)
# ==========================================
.terraform/
*.tfstate
*.tfstate.*
crash.log

# ==========================================
# Kubernetes
# ==========================================
*.kubeconfig
```
